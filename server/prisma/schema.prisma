generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SsoUser {
  id           Int      @id @default(autoincrement())
  phone        String?  @unique @db.VarChar(20)
  email        String?  @unique @db.VarChar(100)
  username     String?  @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  nickname     String   @default("") @db.VarChar(50)
  avatar       String   @default("") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bindings  SsoUserBinding[]
  authCodes SsoAuthCode[]

  @@map("sso_users")
}

model SsoApp {
  id          Int      @id @default(autoincrement())
  appKey      String   @unique @map("app_key") @db.VarChar(50)
  appSecret   String   @map("app_secret") @db.VarChar(100)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  icon        String?  @db.VarChar(500)
  url         String   @db.VarChar(500)
  callbackUrl String   @map("callback_url") @db.VarChar(500)
  status      Int      @default(1) @db.TinyInt
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  bindings  SsoUserBinding[]
  authCodes SsoAuthCode[]

  @@map("sso_apps")
}

model SsoUserBinding {
  id          Int      @id @default(autoincrement())
  ssoUserId   Int      @map("sso_user_id")
  appKey      String   @map("app_key") @db.VarChar(50)
  localUserId String   @map("local_user_id") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  ssoUser SsoUser @relation(fields: [ssoUserId], references: [id])
  ssoApp  SsoApp  @relation(fields: [appKey], references: [appKey])

  @@unique([ssoUserId, appKey])
  @@map("sso_user_bindings")
}

model SsoAuthCode {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(100)
  ssoUserId   Int      @map("sso_user_id")
  appKey      String   @map("app_key") @db.VarChar(50)
  redirectUri String   @map("redirect_uri") @db.VarChar(500)
  expiresAt   DateTime @map("expires_at")
  used        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  ssoUser SsoUser @relation(fields: [ssoUserId], references: [id])
  ssoApp  SsoApp  @relation(fields: [appKey], references: [appKey])

  @@map("sso_auth_codes")
}
